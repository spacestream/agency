# Set one or both API keys. PROVIDER selects which to use.
PROVIDER=openai

ANTHROPIC_API_KEY=your-api-key-here
OPENAI_API_KEY=your-openai-key-here

# OpenAI auth method: "apikey" (default) or "oauth" (browser-based ChatGPT login)
OPENAI_AUTH=oauth

# OpenAI model (e.g. gpt-4o for API key, codex-mini for ChatGPT OAuth)
OPENAI_MODEL=gpt-5.2-codex

PROJECT_DIR=./projects
PORT=3000
